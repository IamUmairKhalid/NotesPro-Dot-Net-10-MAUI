<?xml version="1.0" encoding="utf-8" ?>

<ContentView
    x:Class="NotesPro.Controls.SearchBarView"
    xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
    xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
    x:Name="Root">

    <Border
        Padding="{StaticResource Space12}"
        BackgroundColor="{StaticResource SearchBackground}"
        Stroke="{StaticResource Outline}"
        StrokeThickness="1">

        <Border.StrokeShape>
            <RoundRectangle CornerRadius="{StaticResource RadiusLarge}" />
        </Border.StrokeShape>

        <Grid
            ColumnDefinitions="Auto,*,Auto"
            ColumnSpacing="{StaticResource Space8}">

            <Path
                Grid.Column="0"
                Aspect="Uniform"
                Data="M9.5,3A6.5,6.5 0,0 1,16,9.5C16,11.1 15.41,12.57 14.44,13.69L20.37,19.62L19.62,20.37L13.69,14.44C12.57,15.41 11.1,16 9.5,16A6.5,6.5 0,0 1,3,9.5A6.5,6.5 0,0 1,9.5,3M9.5,4.5A5,5 0,0 0,4.5,9.5A5,5 0,0 0,9.5,14.5A5,5 0,0 0,14.5,9.5A5,5 0,0 0,9.5,4.5Z"
                Fill="{StaticResource SecondaryBrush}"
                WidthRequest="20"
                HeightRequest="20"
                VerticalOptions="Center" />

            <Entry
                Grid.Column="1"
                BackgroundColor="Transparent"
                Placeholder="{Binding Placeholder, Source={x:Reference Root}}"
                TextColor="{StaticResource OnSurface}"
                Text="{Binding Text,
                               Source={x:Reference Root},
                               Mode=TwoWay}" />

            <Border
                x:Name="ClearButton"
                Grid.Column="2"
                WidthRequest="32"
                HeightRequest="32"
                StrokeThickness="0"
                BackgroundColor="Transparent"
                VerticalOptions="Center">

                <Path
                    Aspect="Uniform"
                    Data="M18.3,5.71L16.89,4.29L12,9.17L7.11,4.29L5.7,5.71L10.59,10.59L5.7,15.48L7.11,16.9L12,12L16.89,16.9L18.3,15.48L13.41,10.59L18.3,5.71Z"
                    Fill="{StaticResource SecondaryBrush}"
                    HorizontalOptions="Center"
                    VerticalOptions="Center"
                    WidthRequest="18"
                    HeightRequest="18" />
            </Border>

        </Grid>

    </Border>

</ContentView>
