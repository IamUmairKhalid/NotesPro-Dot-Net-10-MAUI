<?xml version="1.0" encoding="utf-8" ?>

<ContentView
    x:Class="NotesPro.Controls.StatisticCard"
    xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
    xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
    x:Name="Root">

    <Border
        BackgroundColor="{StaticResource CardBackground}"
        Padding="{StaticResource Space16}"
        Stroke="{StaticResource Outline}"
        StrokeThickness="1">

        <Border.StrokeShape>
            <RoundRectangle CornerRadius="{StaticResource RadiusLarge}" />
        </Border.StrokeShape>

        <VerticalStackLayout
            Spacing="{StaticResource Space12}">

            <Grid
                ColumnDefinitions="Auto,*">

                <Border
                    WidthRequest="42"
                    HeightRequest="42"
                    BackgroundColor="{StaticResource PrimaryContainer}"
                    StrokeThickness="0">

                    <Border.StrokeShape>
                        <RoundRectangle CornerRadius="21"/>
                    </Border.StrokeShape>

                    <Label
                        HorizontalOptions="Center"
                        VerticalOptions="Center"
                        FontSize="18"
                        Text="{Binding Icon, Source={x:Reference Root}}"/>

                </Border>

            </Grid>

            <Label
                Style="{StaticResource DisplayLarge}"
                Text="{Binding Value, Source={x:Reference Root}}"/>

            <Label
                Style="{StaticResource BodyMedium}"
                Text="{Binding Title, Source={x:Reference Root}}"
                TextColor="{StaticResource Secondary}"/>

        </VerticalStackLayout>

    </Border>

</ContentView>