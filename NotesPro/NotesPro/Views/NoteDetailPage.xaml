<?xml version="1.0" encoding="utf-8" ?>

<ContentPage
    x:Class="NotesPro.Views.NoteDetailPage"
    xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
    xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
    xmlns:viewModels="clr-namespace:NotesPro.ViewModels"
    xmlns:models="clr-namespace:NotesPro.Models"
    xmlns:controls="clr-namespace:NotesPro.Controls"
    x:DataType="viewModels:NoteDetailViewModel"
    Shell.NavBarIsVisible="False"
    BackgroundColor="{StaticResource Background}">

    <Grid RowDefinitions="Auto,*,Auto" Padding="{StaticResource Space20}">

        <Grid Grid.Row="0" ColumnDefinitions="Auto,*,Auto" ColumnSpacing="{StaticResource Space12}" Margin="0,10,0,20">
            <Border
                Grid.Column="0"
                WidthRequest="42"
                HeightRequest="42"
                BackgroundColor="{StaticResource Surface}"
                Stroke="{StaticResource Outline}"
                StrokeThickness="1">
                <Border.StrokeShape>
                    <RoundRectangle CornerRadius="21" />
                </Border.StrokeShape>
                <Border.GestureRecognizers>
                    <TapGestureRecognizer Command="{Binding CancelCommand}" />
                </Border.GestureRecognizers>
                <Path
                    Aspect="Uniform"
                    Data="M20,11V13H7.83L13.42,18.59L12,20L4,12L12,4L13.42,5.41L7.83,11H20Z"
                    Fill="{StaticResource OnSurfaceBrush}"
                    WidthRequest="22"
                    HeightRequest="22"
                    HorizontalOptions="Center"
                    VerticalOptions="Center" />
            </Border>

            <Label
                Grid.Column="1"
                Text="{Binding Title}"
                Style="{StaticResource TitleLarge}"
                HorizontalOptions="Center"
                VerticalOptions="Center" />

            <HorizontalStackLayout Grid.Column="2" Spacing="{StaticResource Space8}" VerticalOptions="Center">
                <Border
                    WidthRequest="42"
                    HeightRequest="42"
                    BackgroundColor="{StaticResource Surface}"
                    Stroke="{StaticResource Outline}"
                    StrokeThickness="1">
                    <Border.StrokeShape>
                        <RoundRectangle CornerRadius="21" />
                    </Border.StrokeShape>
                    <Border.GestureRecognizers>
                        <TapGestureRecognizer Command="{Binding TogglePinCommand}" />
                    </Border.GestureRecognizers>
                    <Border.Triggers>
                        <DataTrigger TargetType="Border" Binding="{Binding IsPinned}" Value="True">
                            <Setter Property="BackgroundColor" Value="{StaticResource PrimaryContainer}" />
                            <Setter Property="Stroke" Value="{StaticResource Primary}" />
                        </DataTrigger>
                    </Border.Triggers>
                    <Path
                        Aspect="Uniform"
                        Data="M16,12V4H17V2H7V4H8V12L6,14V16H11.2V22H12.8V16H18V14L16,12M8.8,14L10,12.8V4H14V12.8L15.2,14H8.8Z"
                        Fill="{StaticResource SecondaryBrush}"
                        WidthRequest="20"
                        HeightRequest="20"
                        HorizontalOptions="Center"
                        VerticalOptions="Center">
                        <Path.Triggers>
                            <DataTrigger TargetType="Path" Binding="{Binding IsPinned}" Value="True">
                                <Setter Property="Fill" Value="{StaticResource PrimaryBrush}" />
                            </DataTrigger>
                        </Path.Triggers>
                    </Path>
                </Border>

                <Border
                    WidthRequest="42"
                    HeightRequest="42"
                    BackgroundColor="{StaticResource Surface}"
                    Stroke="{StaticResource Outline}"
                    StrokeThickness="1">
                    <Border.StrokeShape>
                        <RoundRectangle CornerRadius="21" />
                    </Border.StrokeShape>
                    <Border.GestureRecognizers>
                        <TapGestureRecognizer Command="{Binding ToggleFavoriteCommand}" />
                    </Border.GestureRecognizers>
                    <Border.Triggers>
                        <DataTrigger TargetType="Border" Binding="{Binding IsFavorite}" Value="True">
                            <Setter Property="BackgroundColor" Value="#FEF3C7" />
                            <Setter Property="Stroke" Value="{StaticResource Warning}" />
                        </DataTrigger>
                    </Border.Triggers>
                    <Path
                        Aspect="Uniform"
                        Data="M12,17.27L18.18,21L16.54,13.97L22,9.24L14.81,8.62L12,2L9.19,8.62L2,9.24L7.45,13.97L5.82,21L12,17.27Z"
                        Fill="{StaticResource SecondaryBrush}"
                        WidthRequest="20"
                        HeightRequest="20"
                        HorizontalOptions="Center"
                        VerticalOptions="Center">
                        <Path.Triggers>
                            <DataTrigger TargetType="Path" Binding="{Binding IsFavorite}" Value="True">
                                <Setter Property="Fill" Value="{StaticResource WarningBrush}" />
                            </DataTrigger>
                        </Path.Triggers>
                    </Path>
                </Border>
            </HorizontalStackLayout>
        </Grid>

        <ScrollView Grid.Row="1">
            <VerticalStackLayout Spacing="{StaticResource Space20}">

                <VerticalStackLayout Spacing="{StaticResource Space8}">
                    <Label Text="Category" Style="{StaticResource BodyMedium}" TextColor="{StaticResource Secondary}" />
                    <CollectionView
                        SelectionMode="Single"
                        SelectedItem="{Binding SelectedCategory}"
                        ItemsSource="{Binding Categories}"
                        HeightRequest="56">
                        <CollectionView.ItemsLayout>
                            <LinearItemsLayout Orientation="Horizontal" ItemSpacing="8" />
                        </CollectionView.ItemsLayout>
                        <CollectionView.ItemTemplate>
                            <DataTemplate x:DataType="models:Category">
                                <Grid Padding="2">
                                    <VisualStateManager.VisualStateGroups>
                                        <VisualStateGroup Name="CommonStates">
                                            <VisualState Name="Normal">
                                                <VisualState.Setters>
                                                    <Setter TargetName="CardBorder" Property="Border.BackgroundColor" Value="{StaticResource Surface}" />
                                                    <Setter TargetName="CardBorder" Property="Border.StrokeThickness" Value="1" />
                                                </VisualState.Setters>
                                            </VisualState>
                                            <VisualState Name="Selected">
                                                <VisualState.Setters>
                                                    <Setter TargetName="CardBorder" Property="Border.BackgroundColor" Value="{StaticResource PrimaryContainer}" />
                                                    <Setter TargetName="CardBorder" Property="Border.StrokeThickness" Value="2" />
                                                </VisualState.Setters>
                                            </VisualState>
                                        </VisualStateGroup>
                                    </VisualStateManager.VisualStateGroups>
                                    <Border
                                        x:Name="CardBorder"
                                        Padding="16,8"
                                        Stroke="{Binding Color}"
                                        HeightRequest="42">
                                        <Border.StrokeShape>
                                            <RoundRectangle CornerRadius="21" />
                                        </Border.StrokeShape>
                                        <HorizontalStackLayout Spacing="8" VerticalOptions="Center">
                                            <BoxView WidthRequest="10" HeightRequest="10" CornerRadius="5" Color="{Binding Color}" VerticalOptions="Center" />
                                            <Label Text="{Binding Name}" FontSize="14" FontFamily="OpenSansSemibold" TextColor="{StaticResource OnSurface}" VerticalOptions="Center" />
                                        </HorizontalStackLayout>
                                    </Border>
                                </Grid>
                            </DataTemplate>
                        </CollectionView.ItemTemplate>
                    </CollectionView>
                </VerticalStackLayout>

                <VerticalStackLayout Spacing="{StaticResource Space8}">
                    <Label Text="Title" Style="{StaticResource BodyMedium}" TextColor="{StaticResource Secondary}" />
                    <Border Stroke="{StaticResource Outline}" Padding="12,0" StrokeThickness="1" BackgroundColor="{StaticResource Surface}">
                        <Border.StrokeShape>
                            <RoundRectangle CornerRadius="12" />
                        </Border.StrokeShape>
                        <Entry
                            Text="{Binding NoteTitle}"
                            Placeholder="Title of your note..."
                            TextColor="{StaticResource OnSurface}"
                            FontSize="18"
                            FontFamily="OpenSansSemibold"
                            BackgroundColor="Transparent"
                            HeightRequest="50" />
                    </Border>
                </VerticalStackLayout>

                <VerticalStackLayout Spacing="{StaticResource Space8}">
                    <Label Text="Content" Style="{StaticResource BodyMedium}" TextColor="{StaticResource Secondary}" />
                    <Border Stroke="{StaticResource Outline}" Padding="12" StrokeThickness="1" BackgroundColor="{StaticResource Surface}">
                        <Border.StrokeShape>
                            <RoundRectangle CornerRadius="12" />
                        </Border.StrokeShape>
                        <Editor
                            Text="{Binding NoteDescription}"
                            Placeholder="Start writing here..."
                            TextColor="{StaticResource OnSurface}"
                            FontSize="16"
                            BackgroundColor="Transparent"
                            HeightRequest="300"
                            AutoSize="Disabled" />
                    </Border>
                </VerticalStackLayout>

            </VerticalStackLayout>
        </ScrollView>

        <Grid Grid.Row="2" ColumnDefinitions="*,Auto" ColumnSpacing="{StaticResource Space12}" Margin="0,10,0,0">
            <controls:PrimaryButton
                Grid.Column="0"
                Text="Save Note"
                Command="{Binding SaveCommand}"
                IsLoading="{Binding IsBusy}" />

            <Border
                Grid.Column="1"
                WidthRequest="56"
                HeightRequest="56"
                BackgroundColor="{StaticResource Danger}"
                StrokeThickness="0"
                IsVisible="{Binding IsEditMode}">
                <Border.StrokeShape>
                    <RoundRectangle CornerRadius="16" />
                </Border.StrokeShape>
                <Border.GestureRecognizers>
                    <TapGestureRecognizer Command="{Binding DeleteCommand}" />
                </Border.GestureRecognizers>
                <Path
                    Aspect="Uniform"
                    Data="M6,19C6,20.1 6.9,21 8,21H16C17.1,21 18,20.1 18,19V7H6V19M8,9H16V19H8V9M15.5,4L14.5,3H9.5L8.5,4H5V6H19V4H15.5Z"
                    Fill="{StaticResource OnPrimaryBrush}"
                    WidthRequest="24"
                    HeightRequest="24"
                    HorizontalOptions="Center"
                    VerticalOptions="Center" />
            </Border>
        </Grid>

    </Grid>

</ContentPage>
