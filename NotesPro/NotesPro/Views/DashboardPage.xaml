<?xml version="1.0" encoding="utf-8" ?>

<ContentPage
    x:Class="NotesPro.Views.DashboardPage"
    xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
    xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
    xmlns:viewModels="clr-namespace:NotesPro.ViewModels"
    xmlns:controls="clr-namespace:NotesPro.Controls"
    xmlns:models="clr-namespace:NotesPro.Models"
    x:DataType="viewModels:DashboardViewModel"
    x:Name="PageRoot"
    Shell.NavBarIsVisible="False"
    BackgroundColor="{StaticResource Background}">

    <RefreshView
        IsRefreshing="{Binding IsRefreshing}"
        Command="{Binding LoadCommand}">

        <ScrollView>

            <VerticalStackLayout
                Padding="{StaticResource Space20}"
                Spacing="{StaticResource Space20}">

                <!-- Logo & Brand Header -->
                <HorizontalStackLayout Spacing="10" Margin="0,0,0,10" VerticalOptions="Center">
                    <Border WidthRequest="36"
                            HeightRequest="36"
                            BackgroundColor="{StaticResource Primary}"
                            StrokeThickness="0">
                        <Border.StrokeShape>
                            <RoundRectangle CornerRadius="10"/>
                        </Border.StrokeShape>
                        <Path Data="M19,3H5c-1.1,0-2,.9-2,2v14c0,1.1,.9,2,2,2h14c1.1,0,2-.9,2-2V5c0-1.1-.9-2-2-2zm-2,10H7v-2h10v2zm0-4H7V7h10v2z"
                              Fill="White"
                              Aspect="Uniform"
                              WidthRequest="18"
                              HeightRequest="18"
                              HorizontalOptions="Center"
                              VerticalOptions="Center" />
                    </Border>
                    <Label Text="NotesPro"
                           FontFamily="OpenSansSemibold"
                           FontSize="20"
                           TextColor="{StaticResource Primary}"
                           VerticalOptions="Center"/>
                </HorizontalStackLayout>

                <!-- Header -->

                <VerticalStackLayout
                    Spacing="{StaticResource Space4}">

                    <Label
                        Style="{StaticResource DisplayLarge}"
                        Text="{Binding Greeting}" />

                    <Label
                        Style="{StaticResource BodyMedium}"
                        Text="Welcome back," />

                    <Label
                        Style="{StaticResource HeadlineMedium}"
                        Text="{Binding UserName}" />

                    <Label
                        Style="{StaticResource BodySmall}"
                        Text="{Binding TodayDate}"
                        TextColor="{StaticResource Secondary}" />

                </VerticalStackLayout>

                <!-- Search -->

                <controls:SearchBarView
                    Placeholder="Search notes..."
                    Text="{Binding SearchText}" />

                <!-- Statistics -->

                <Grid
                    ColumnDefinitions="*,*,*"
                    ColumnSpacing="{StaticResource Space12}">

                    <controls:StatisticCard
                        Grid.Column="0"
                        Icon="Notes"
                        Title="Notes"
                        Value="{Binding TotalNotes}" />

                    <controls:StatisticCard
                        Grid.Column="1"
                        Icon="Favorites"
                        Title="Favorites"
                        Value="{Binding FavoriteNotes}" />

                    <controls:StatisticCard
                        Grid.Column="2"
                        Icon="Pinned"
                        Title="Pinned"
                        Value="{Binding PinnedNotes}" />

                </Grid>

                <!-- Recent Notes -->

                <Label
                    Style="{StaticResource TitleLarge}"
                    Text="Recent Notes" />

                <CollectionView
                    ItemsSource="{Binding RecentNotes}"
                    SelectedItem="{Binding SelectedNote, Mode=TwoWay}"
                    SelectionMode="Single">

                    <CollectionView.ItemTemplate>

                        <DataTemplate x:DataType="models:Note">

                            <controls:NoteCard
                                Title="{Binding Title}"
                                Description="{Binding Description}"
                                Date="{Binding CreatedOn, StringFormat='{0:dd MMM yyyy}'}"
                                IsPinned="{Binding IsPinned}"
                                IsFavorite="{Binding IsFavorite}" />

                        </DataTemplate>

                    </CollectionView.ItemTemplate>

                </CollectionView>

            </VerticalStackLayout>

        </ScrollView>

    </RefreshView>

</ContentPage>
