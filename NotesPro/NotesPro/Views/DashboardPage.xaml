<?xml version="1.0" encoding="utf-8" ?>

<ContentPage
    x:Class="NotesPro.Views.DashboardPage"
    xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
    xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
    xmlns:viewModels="clr-namespace:NotesPro.ViewModels"
    xmlns:controls="clr-namespace:NotesPro.Controls"
    x:DataType="viewModels:DashboardViewModel"
    Shell.NavBarIsVisible="False"
    BackgroundColor="{StaticResource Background}">

    <RefreshView
        IsRefreshing="{Binding IsBusy}"
        Command="{Binding LoadCommand}">

        <ScrollView>

            <VerticalStackLayout
                Padding="{StaticResource Space20}"
                Spacing="{StaticResource Space20}">

                <!-- Header -->

                <VerticalStackLayout
                    Spacing="{StaticResource Space4}">

                    <Label
                        Style="{StaticResource DisplayLarge}"
                        Text="{Binding Greeting}" />

                    <Label
                        Style="{StaticResource BodyMedium}"
                        Text="Welcome back," />

                    <Label
                        Style="{StaticResource HeadlineMedium}"
                        Text="{Binding UserName}" />

                    <Label
                        Style="{StaticResource BodySmall}"
                        Text="{Binding TodayDate}"
                        TextColor="{StaticResource Secondary}" />

                </VerticalStackLayout>

                <!-- Search -->

                <controls:SearchBarView
                    Placeholder="Search notes..." />

                <!-- Statistics -->

                <Grid
                    ColumnDefinitions="*,*,*"
                    ColumnSpacing="{StaticResource Space12}">

                    <controls:StatisticCard
                        Grid.Column="0"
                        Icon="📝"
                        Title="Notes"
                        Value="{Binding TotalNotes}" />

                    <controls:StatisticCard
                        Grid.Column="1"
                        Icon="⭐"
                        Title="Favorites"
                        Value="{Binding FavoriteNotes}" />

                    <controls:StatisticCard
                        Grid.Column="2"
                        Icon="📌"
                        Title="Pinned"
                        Value="{Binding PinnedNotes}" />

                </Grid>

                <!-- Recent Notes -->

                <Label
                    Style="{StaticResource TitleLarge}"
                    Text="Recent Notes" />

                <CollectionView
                    ItemsSource="{Binding RecentNotes}"
                    SelectionMode="None">

                    <CollectionView.ItemTemplate>

                        <DataTemplate>

                            <controls:NoteCard
                                Title="{Binding Title}"
                                Description="{Binding Description}"
                                Date="{Binding CreatedOn, StringFormat='{0:dd MMM yyyy}'}"
                                IsPinned="{Binding IsPinned}"
                                IsFavorite="{Binding IsFavorite}" />

                        </DataTemplate>

                    </CollectionView.ItemTemplate>

                </CollectionView>

            </VerticalStackLayout>

        </ScrollView>

    </RefreshView>

</ContentPage>