<?xml version="1.0" encoding="utf-8" ?>

<ContentPage
    x:Class="NotesPro.Views.DashboardPage"
    xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
    xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
    xmlns:viewModels="clr-namespace:NotesPro.ViewModels"
    x:DataType="viewModels:DashboardViewModel"
    Title="Dashboard">

    <ScrollView>

        <VerticalStackLayout
            Padding="24"
            Spacing="20">

            <Label
                FontSize="32"
                FontAttributes="Bold"
                Text="{Binding Greeting}" />

            <Label
                FontSize="22"
                Text="{Binding UserName}" />

            <Border
                Padding="20"
                BackgroundColor="{StaticResource CardBackgroundColor}"
                Stroke="{StaticResource BorderColor}"
                StrokeThickness="1">

                <VerticalStackLayout
                    Spacing="8">

                    <Label
                        FontSize="14"
                        Text="Today's Goal" />

                    <Label
                        FontSize="22"
                        FontAttributes="Bold"
                        Text="{Binding TodayGoal}" />

                </VerticalStackLayout>

            </Border>

            <Button
                Text="Continue"
                Command="{Binding StartCommand}" />

        </VerticalStackLayout>

    </ScrollView>

</ContentPage>