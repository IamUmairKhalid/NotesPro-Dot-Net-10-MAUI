<?xml version="1.0" encoding="utf-8" ?>

<ContentPage
    x:Class="NotesPro.Views.DashboardPage"
    xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
    xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
    xmlns:viewModels="clr-namespace:NotesPro.ViewModels"
    x:DataType="viewModels:DashboardViewModel"
    Title="Dashboard">

    <ScrollView>

        <VerticalStackLayout Padding="20" Spacing="16">

            <Label
        FontSize="28"
        FontAttributes="Bold"
        Text="Dashboard"/>

            <Border Padding="16">

                <VerticalStackLayout>

                    <Label Text="Total Notes"/>

                    <Label
                FontSize="26"
                FontAttributes="Bold"
                Text="{Binding TotalNotes}"/>

                </VerticalStackLayout>

            </Border>

            <Border Padding="16">

                <VerticalStackLayout>

                    <Label Text="Favorites"/>

                    <Label
                FontSize="26"
                FontAttributes="Bold"
                Text="{Binding FavoriteNotes}"/>

                </VerticalStackLayout>

            </Border>

            <Border Padding="16">

                <VerticalStackLayout>

                    <Label Text="Pinned"/>

                    <Label
                FontSize="26"
                FontAttributes="Bold"
                Text="{Binding PinnedNotes}"/>

                </VerticalStackLayout>

            </Border>

            <CollectionView ItemsSource="{Binding RecentNotes}">

                <CollectionView.ItemTemplate>

                    <DataTemplate>

                        <Border Padding="12">

                            <VerticalStackLayout>

                                <Label
                            FontAttributes="Bold"
                            Text="{Binding Title}"/>

                                <Label
                            FontSize="12"
                            Text="{Binding Description}"/>

                            </VerticalStackLayout>

                        </Border>

                    </DataTemplate>

                </CollectionView.ItemTemplate>

            </CollectionView>

        </VerticalStackLayout>

    </ScrollView>

</ContentPage>