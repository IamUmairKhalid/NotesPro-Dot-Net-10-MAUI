<?xml version="1.0" encoding="utf-8" ?>
<ResourceDictionary
    xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
    xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml">

    <!-- Base spacing values -->

    <x:Double x:Key="Space0">0</x:Double>

    <x:Double x:Key="Space2">2</x:Double>

    <x:Double x:Key="Space4">4</x:Double>

    <x:Double x:Key="Space8">8</x:Double>

    <x:Double x:Key="Space12">12</x:Double>

    <x:Double x:Key="Space16">16</x:Double>

    <x:Double x:Key="Space20">20</x:Double>

    <x:Double x:Key="Space24">24</x:Double>

    <x:Double x:Key="Space32">32</x:Double>

    <x:Double x:Key="Space40">40</x:Double>

    <x:Double x:Key="Space48">48</x:Double>

    <x:Double x:Key="Space56">56</x:Double>

    <x:Double x:Key="Space64">64</x:Double>

    <!-- Corner Radius -->

    <CornerRadius x:Key="RadiusSmall">8</CornerRadius>

    <CornerRadius x:Key="RadiusMedium">16</CornerRadius>

    <CornerRadius x:Key="RadiusLarge">24</CornerRadius>

    <CornerRadius x:Key="RadiusXLarge">32</CornerRadius>

</ResourceDictionary>